# Dependencies
node_modules/

# Build output
dist/

# Turbo
.turbo/

# Akash deploy state — leases (mutable, contains DSEQ + provider) and the
# ATOR probe's v3 hidden-service keypair. The secret key is sensitive — never
# commit it. The .anyone hostname is derived from the public key; if that
# directory is removed, redeploying ator-probe generates a fresh hostname.
deploy/akash/leases.json
deploy/akash/denylist.json
deploy/akash/ator-probe-keys/

# Vendored external sources cloned by build scripts (e.g. Town-Frontend)
.cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
.env.*.local
.env.publish
.env.oyster
.env.oyster.runtime
.env.sdk-e2e

# Test
coverage/
**/data/*.db
# Local e2e log dirs
e2e-real-hs-logs/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Legal documents (private, not for version control)
_bmad-output/legal/

# Misc
*.tgz
.auto-bmad-tmp/

# Python bytecode
__pycache__/
*.pyc

# Claude Code local config (exclude skills/ which are project deliverables)
.claude/*
!.claude/skills/

# MCP config
.mcp.json

# Backup files
*.backup

# Images
*.png
*.jpg
*.jpeg
!_bmad-output/branding/**/*.png
!_bmad-output/dev-signals/assets/**/*.png

# Nix build output (symlink to /nix/store result)
/result

# Devbox local shell (Nix symlinks/cache — devbox.json and devbox.lock are committed)
.devbox/

# Generated deployment files
docker-compose-peer*.yml
genesis.env
.playwright-cli/
wallet-*.yaml

# Local e2e public-testnet dev wallet (never commit the seed phrase)
.env.e2e.local
*.e2e-wallet

# Plugin MCP declaration must be committed (no secrets — just an npx command)
!toon-plugin/.mcp.json
